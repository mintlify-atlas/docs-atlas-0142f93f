  "keyFeatures": [
    "Full coverage of Okta Management API (users, groups, apps, policies, and more)",
    "Multiple authentication modes: API Token (SSWS), OAuth 2.0 Private Key, JWT, and Bearer Token",
    "Built-in request caching with configurable TTL and custom cache implementations",
    "Automatic rate limit handling with configurable retries and backoff",
    "Pagination support via HasNextPage/Next response helpers",
    "DPoP (Demonstrating Proof of Possession) support for enhanced OAuth security",
    "Generated from OpenAPI v3 spec using openapi-generator",
    "Context-aware API calls for cancellation and deadline propagation"
  ],
  "publicApiSurface": [
    "okta.NewConfiguration(...ConfigOption) (*Configuration, error)",
    "okta.NewAPIClient(cfg *Configuration) *APIClient",
    "client.UserAPI - user CRUD, lifecycle, factors, sessions",
    "client.GroupAPI - group CRUD, membership management",
    "client.ApplicationAPI - application CRUD, SSO, provisioning",
    "client.PolicyAPI - policy and rule management",
    "client.AuthorizationServerAPI - OAuth 2.0 authorization servers",
    "client.AuthenticatorAPI - authenticator management",
    "client.IdentityProviderAPI - IdP federation",
    "client.RoleAssignmentAUserAPI / RoleAssignmentBGroupAPI - role assignments",
    "client.SystemLogAPI - audit log access",
    "client.EventHookAPI / InlineHookAPI - hook management",
    "client.SchemaAPI - user and group schema customization",
    "okta.WithOrgUrl / WithToken / WithAuthorizationMode / WithPrivateKey - config setters",
    "cache.Cache interface - custom caching implementations",
    "APIResponse.HasNextPage() / Next() - pagination helpers"
  ]
}
